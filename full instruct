### `app/crud.py`

```python
# app/crud.py
from typing import Dict, Any
from sqlalchemy.orm import Session

from app.db import SessionLocal
from app import models


def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()


def get_pricing_rule(db: Session, model: str):
    return db.query(models.PricingRule).filter(models.PricingRule.model == model).first()


def create_usage_event(
    tenant_id: str,
    model: str,
    units: float,
    cost_estimate: float,
    meta: Dict[str, Any],
):
    db = SessionLocal()
    try:
        event = models.UsageEvent(
            tenant_id=int(tenant_id) if tenant_id.isdigit() else None,
            model=model,
            units=units,
            cost_estimate=cost_estimate,
            meta=meta,
        )
        db.add(event)
        db.commit()
        db.refresh(event)
        return event
    finally:
        db.close()


def meter_usage(tenant_id: str, model: str, units: float) -> float:
    """
    Simple cost estimate: look up PricingRule, or fall back to in-memory PRICING.
    """
    db = SessionLocal()
    try:
        rule = get_pricing_rule(db, model)
        if rule:
            return units * rule.unit_price
        # Fallback: caller provides pricing
        # You can override this by wiring in-memory PRICING
        return 0.0
    finally:
        db.close()
```

