### `tm.middleman.quote`

- Purpose: Ask “what will this cost?” before executing.
- Signature:

```json
{
  "name": "tm.middleman.quote",
  "version": "1.0.0",
  "description": "Get a cost quote and metadata for a given model before execution.",
  "input_schema": {
    "type": "object",
    "required": ["model_id"],
    "properties": {
      "model_id": {
        "type": "string",
        "description": "Tap919 model identifier to quote."
      },
      "estimated_tokens": {
        "type": "number",
        "description": "Optional estimated token count to compute estimated cost for token-based models."
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["model", "unit_price", "unit_type"],
    "properties": {
      "model": {
        "type": "string",
        "description": "Model identifier quoted."
      },
      "unit_price": {
        "type": "number",
        "description": "Price per unit (per call, per task, per 1k tokens)."
      },
      "unit_type": {
        "type": "string",
        "enum": ["per_call", "per_task", "per_1k_tokens"],
        "description": "Unit for billing."
      },
      "provider": {
        "type": "string",
        "description": "Underlying provider (openai, replicate, tap919, etc.)."
      },
      "estimated_cost": {
        "type": "number",
        "description": "Optional computed cost from estimated_tokens, if provided."
      },
      "estimated_latency_ms": {
        "type": "number",
        "description": "Estimated latency in milliseconds."
      }
    }
  }
}
```

