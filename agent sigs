Here are clean capability signatures (cap sigs) for the first core agents and services, in a format we can plug straight into a Shared Protocol / Capability Registry.

***

## 1. Middleman Core Capabilities

These wrap the FastAPI endpoints you already have or are about to expose.

### `tm.middleman.execute`

- Purpose: Run a model/agent through Middleman, meter it, and get cost + output.
- Signature:

```json
{
  "name": "tm.middleman.execute",
  "version": "1.0.0",
  "description": "Execute a Tap919 model via Middleman, with usage metering and cost estimation.",
  "input_schema": {
    "type": "object",
    "required": ["tenant_id", "model_id", "input"],
    "properties": {
      "tenant_id": {
        "type": "string",
        "description": "Tenant or account identifier attached to this call."
      },
      "model_id": {
        "type": "string",
        "description": "Tap919 model identifier (e.g., 'affiliate:gpt4-mini', 'tap919:blackmind-lite')."
      },
      "input": {
        "type": "string",
        "description": "Prompt or instruction payload for the model."
      },
      "params": {
        "type": "object",
        "description": "Optional provider/model-specific parameters (temperature, max_tokens, etc.).",
        "additionalProperties": true
      },
      "trace_meta": {
        "type": "object",
        "description": "Optional tracing or correlation metadata.",
        "additionalProperties": true
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["model", "output", "usage"],
    "properties": {
      "model": {
        "type": "string",
        "description": "Resolved model identifier used for execution."
      },
      "output": {
        "type": "string",
        "description": "Raw output text returned from downstream provider or local model."
      },
      "usage": {
        "type": "object",
        "required": ["units", "unit_type", "cost_estimate"],
        "properties": {
          "units": {
            "type": "number",
            "description": "Quantity used (e.g., 1 task, 1.23 units of 1k tokens)."
          },
          "unit_type": {
            "type": "string",
            "enum": ["per_call", "per_task", "per_1k_tokens"],
            "description": "Metric the pricing uses for this call."
          },
          "cost_estimate": {
            "type": "number",
            "description": "Estimated cost in billing currency for this single call."
          }
        }
      }
    }
  }
}
```

