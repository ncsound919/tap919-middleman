## 3. Routing / Telemetry Capabilities

### `tm.routing.score_providers`

- Purpose: Let the Middleman Router agent decide how to route traffic across providers based on cost/latency/reliability. [blog.axway](https://blog.axway.com/learning-center/apis/enterprise-api-strategy/api-monetization-models)

```json
{
  "name": "tm.routing.score_providers",
  "version": "1.0.0",
  "description": "Score and rank providers for a given model family based on cost, latency, and error rates.",
  "input_schema": {
    "type": "object",
    "required": ["model_family", "candidates"],
    "properties": {
      "model_family": {
        "type": "string",
        "description": "Logical model family (e.g., 'gpt4-class', 'embed-basic')."
      },
      "candidates": {
        "type": "array",
        "description": "Provider candidates to score.",
        "items": {
          "type": "object",
          "required": ["provider", "price", "latency_ms", "error_rate"],
          "properties": {
            "provider": {
              "type": "string",
              "description": "Provider identifier (openai, anthropic, local-nvidia, etc.)."
            },
            "price": {
              "type": "number",
              "description": "Price per unit for this provider."
            },
            "latency_ms": {
              "type": "number",
              "description": "Recent p95 latency."
            },
            "error_rate": {
              "type": "number",
              "description": "Recent error rate (0-1)."
            }
          }
        }
      },
      "tenant_constraints": {
        "type": "object",
        "description": "Optional tenant restrictions (regions, providers to avoid, budget caps).",
        "additionalProperties": true
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": ["ranking"],
    "properties": {
      "ranking": {
        "type": "array",
        "description": "Providers ordered best to worst.",
        "items": {
          "type": "object",
          "required": ["provider", "score"],
          "properties": {
            "provider": {
              "type": "string"
            },
            "score": {
              "type": "number",
              "description": "Relative score (higher is better)."
            },
            "reason": {
              "type": "string",
              "description": "Human-readable explanation for XAI."
            }
          }
        }
      },
      "recommended_provider": {
        "type": "string",
        "description": "Top choice provider."
      }
    }
  }
}
```

